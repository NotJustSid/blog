# Normalize all text files to LF on commit
* text=auto eol=lf

# Explicitly declare common text file types
*.md text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.rb text eol=lf
*.xml text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.pdf binary
*.pem binary
